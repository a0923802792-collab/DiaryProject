@model DiaryProject.ViewModels.Review.ReviewDaySummaryViewModel

@{
    var diaryDateText = Model.DiaryDate.ToString("M月d日");
}

<div class="modal-head">
    <div>
        <p class="eyebrow">Diary Detail</p>
        <h3>@Model.DateText</h3>
    </div>

    <button type="button" class="icon-btn" data-close-review-modal>×</button>
</div>

<div class="review-modal-body">
    @if (!string.IsNullOrEmpty(Model.Title))
    {
        <h4>@Model.Title</h4>
    }

    <p>@Model.PreviewText</p>

    <div class="review-meta-list">
        @if (!string.IsNullOrEmpty(Model.MainMoodName))
        {
            <span class="review-chip">@Model.MainMoodEmoji @Model.MainMoodName</span>
        }

        <span class="review-chip">能量 @(Model.EnergyValue?.ToString() ?? "-")</span>
        <span class="review-chip">壓力 @(Model.StressValue?.ToString() ?? "-")</span>
        <span class="review-chip">睡眠 @(Model.SleepValue?.ToString() ?? "-")</span>
    </div>

    @if (Model.Tags.Any())
    {
        <p>標籤：@string.Join("、", Model.Tags)</p>
    }

    @if (Model.PhotoUrls.Any())
    {
        <div>
            <p>照片：</p>

            <div class="review-photo-thumbs">
                @foreach (var url in Model.PhotoUrls)
                {
                    <img src="@url" alt="日記照片" />
                }
            </div>
        </div>
    }
</div>

<div class="modal-actions">
    <a class="btn btn-primary"
           asp-controller="Review"
           asp-action="GoToDiary"
           asp-route-id="@Model.DiaryId"
           data-confirm-diary-link
           data-confirm-diary-date="@diaryDateText">
        前往日記詳情
    </a>

    <button type="button" class="btn btn-ghost" data-close-review-modal>
        關閉
    </button>
</div>