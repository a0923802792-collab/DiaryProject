<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DiaryProject</title>

    <link rel="stylesheet" href="~/css/layout.css" />
    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/modal.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>


<body>
    <header class="topbar">
        <a asp-controller="Home" asp-action="Index" class="topbar-logo">Moody</a>

        <div class="topbar-search-wrap">
            <div class="search-box">
                <span class="search-icon">⌕</span>
                <input class="search-input" type="text" placeholder="Search my journal" />
            </div>
        </div>

        <div class="topbar-actions">
            <button class="top-icon-btn" type="button" aria-label="通知" onclick="openNotification()">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                    <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                </svg>
            </button>
            @* <button type="button" class="action-btn" aria-label="通知">🔔</button> *@
            @* <button type="button" class="action-btn" aria-label="個人資料">👤</button> *@

            <button class="top-icon-btn" type="button" aria-label="使用者">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
            </button>

        </div>
    </header>

    <div class="layout-container">
        <aside class="sidenav-wrapper" aria-label="主選單">
            <nav class="sidenav-box">

                <nav class="side-nav">
                    <a class="nav-icon-btn" href="/Home2/Index" aria-label="首頁" data-tooltip="首頁">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                            <polyline points="9 22 9 12 15 12 15 22" />
                        </svg>
                    </a>

                    <a class="nav-icon-btn" href="/Diary/DiaryList" aria-label="日記編寫" data-tooltip="日記">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                        </svg>
                    </a>

                    <a class="nav-icon-btn" href="/Review/Time" aria-label="回顧頁" data-tooltip="回顧">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <rect x="3" y="4" width="18" height="18" rx="2" />
                            <line x1="16" y1="2" x2="16" y2="6" />
                            <line x1="8" y1="2" x2="8" y2="6" />
                            <line x1="3" y1="10" x2="21" y2="10" />
                        </svg>
                    </a>

                    <a class="nav-icon-btn" href="/Task/Index" aria-label="習慣頁" data-tooltip="任務中心">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 2L13.5 8.5L20 10L13.5 11.5L12 18L10.5 11.5L4 10L10.5 8.5Z" />
                            <path class="icon-fill" d="M5 3L5.5 5L7 5.5L5.5 6L5 8L4.5 6L3 5.5L4.5 5Z" />
                        </svg>
                    </a>

                    <a class="nav-icon-btn" href="/Home/Chart" aria-label="分析頁" data-tooltip="分析">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M3 15a9 9 0 0 1 18 0" />
                            <path d="M12 15V8" />
                            <circle class="icon-fill" cx="12" cy="15" r="2" />
                        </svg>
                    </a>

                    <a class="nav-icon-btn" href="/Home/sharewall4" aria-label="分享牆" data-tooltip="分享牆">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
                        </svg>
                    </a>
                </nav>


            </nav>

            <button type="button" class="giftwall-btn">★</button>
        </aside>

        <main class="page-shell">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>