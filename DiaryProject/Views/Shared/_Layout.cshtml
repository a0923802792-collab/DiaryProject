<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DiaryProject</title>

    <link rel="stylesheet" href="~/css/layout.css" />
    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/modal.css" />

    @RenderSection("Styles", required: false)
</head>
<body>
    <aside class="sidebar" aria-label="主選單">
        <div class="brand">
            <div class="brand-mark">ED</div>
            <div>
                <h1>情緒日記</h1>
                <p>Diary + Task</p>
            </div>
        </div>

        <nav class="side-nav">
            <a asp-controller="Home" asp-action="Index">首頁</a>
            <button type="button">日記頁</button>
            <a asp-controller="Task" asp-action="Index">任務</a>
            <button type="button">月曆回顧</button>
            <button type="button">分析頁</button>
            <button type="button">分享牆</button>
            <button type="button">個人頁</button>
        </nav>

        <div class="side-note">
            <strong>今天不用全做完</strong>
            <p>先回到一個小行動，剩下的可以慢慢接上。</p>
        </div>
    </aside>

    <main class="main">
        @RenderBody()
    </main>
</body>
</html>