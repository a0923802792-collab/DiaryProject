<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DiaryProject</title>

    <link rel="stylesheet" href="~/css/layout.css" />
    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/modal.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <header class="topbar" style="position: relative; z-index: 20000;">
        <a asp-controller="FrontPage" asp-action="Index" class="topbar-logo">Moody</a>

        <div class="topbar-actions">

            @* 2026-05-16 通知選單  *@
            <div class="account-menu-wrapper" id="notifWrapper" style="position: relative;">
                <button id="notifBtn" class="top-icon-btn" type="button" aria-label="通知">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                        <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                    </svg>
                    @* 紅點：未讀數 > 0 才顯示 *@
                    <span id="notifBadge" style="display:none; position:absolute; top:4px; right:4px;
                    width:10px; height:10px; background:#ef4444;
                    border:2px solid white; border-radius:50%;"></span>
                </button>
                <div id="notificationMenu"
                     style="display:none; position:absolute; top:50px; right:0; width:320px;
                    background:white; border:1px solid #000; border-radius:16px;
                    box-shadow:0 4px 12px rgba(0,0,0,.1); z-index:50000; overflow:hidden;
                    max-height:420px; overflow-y:auto;">
                    <div style="display:flex; justify-content:space-between; align-items:center;
                        padding:12px 16px; border-bottom:1px solid #eee;">
                        <strong style="font-family:serif; font-size:16px;">通知</strong>
                        <span id="notifEmpty" style="font-size:12px; color:#999;">目前沒有新通知</span>
                    </div>
                    <div id="notifList"></div>
                </div>
            </div>
            
            @* 帳戶選單（下拉式）*@
            <div class="account-menu-wrapper" style="position: relative;">
                <button id="accountMenuBtn" class="top-icon-btn" type="button" aria-label="帳戶選單">
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                    </svg>
                </button>
                <div id="accountMenu" class="account-menu"
                     style="display:none; position:absolute; top:50px; right:0; width:180px;
                    background:white; border:1px solid #000; border-radius:12px;
                    box-shadow:0 4px 12px rgba(0,0,0,.1); z-index:50000; overflow:hidden;">
                    <a href="/FrontPage/Profile#account"
                           style="display:block; padding:10px 16px; color:#555; text-decoration:none; font-size:14px;">
                        帳戶
                    </a>
                    <a href="/FrontPage/Profile#setting"
                           style="display:block; padding:10px 16px; color:#555; text-decoration:none; font-size:14px;">
                        系統設定
                    </a>
                    <hr style="margin:0; border:none; border-top:1px solid #eee;">
                    <a href="javascript:logoutAndGoWelcome()"
                           style="display:block; padding:10px 16px; color:#dc2626; text-decoration:none; font-size:14px;">
                        登出
                    </a>
                </div>
            </div>

            <script>
                // ===== 帳號下拉 =====
                document.getElementById('accountMenuBtn').addEventListener('click', function (e) {
                    e.stopPropagation();
                    const menu = document.getElementById('accountMenu');
                    menu.style.display = menu.style.display === 'none' ? 'block' : 'none';
                    document.getElementById('notificationMenu').style.display = 'none';
                });

                // ===== 通知鈴鐺 =====
                const notifBtn = document.getElementById('notifBtn');
                const notifMenu = document.getElementById('notificationMenu');
                const notifBadge = document.getElementById('notifBadge');
                const notifList = document.getElementById('notifList');
                const notifEmpty = document.getElementById('notifEmpty');

                // 轉格式：ISO 時間字串 → 「幾分鐘前」
                function timeAgo(iso) {
                    const diff = (Date.now() - new Date(iso).getTime()) / 1000;
                    if (diff < 60) return '剛剛';
                    if (diff < 3600) return `${Math.floor(diff / 60)} 分鐘前`;
                    if (diff < 86400) return `${Math.floor(diff / 3600)} 小時前`;
                    return `${Math.floor(diff / 86400)} 天前`;
                }

                // 通知資料畫到 dropdown 裡
                function renderNotifications(items) {
                    notifList.innerHTML = '';
                    if (!items || items.length === 0) {
                        notifEmpty.style.display = '';
                        return;
                    }
                    notifEmpty.style.display = 'none';
                    items.forEach(item => {
                        const card = document.createElement('div');
                        card.style.cssText = `
                            padding:10px 16px; border-bottom:1px solid #f3f3f3;
                            ${item.isRead ? 'background:white;' : 'background:#fef9e7;'}
                        `;
                        card.innerHTML = `
                            <div style="font-size:14px; color:#333; margin-bottom:4px;">${item.title}</div>
                            <div style="font-size:11px; color:#999;">${timeAgo(item.createdAt)}</div>
                        `;
                        notifList.appendChild(card);
                    });
                }

                // 跟後端拿通知 + 更新紅點
                async function fetchNotifications() {
                    try {
                        const res = await fetch('/api/notifications', { credentials: 'include' });
                        if (!res.ok) return; // 沒登入就靜默
                        const data = await res.json();
                        renderNotifications(data.notifications || []);
                        notifBadge.style.display = (data.unreadCount > 0) ? 'block' : 'none';
                    } catch (err) {
                        console.error('通知載入失敗', err);
                    }
                }

                // 標記全部已讀
                async function markAllRead() {
                    try {
                        await fetch('/api/notifications/mark-read', {
                            method: 'POST', credentials: 'include'
                        });
                    } catch (err) { /* 忽略 */ }
                }

                // 點鈴鐺：開關 dropdown，開的時候去抓一次最新 + 標已讀
                notifBtn.addEventListener('click', function (e) {
                    e.stopPropagation();
                    const willOpen = notifMenu.style.display === 'none';
                    notifMenu.style.display = willOpen ? 'block' : 'none';
                    document.getElementById('accountMenu').style.display = 'none';

                    if (willOpen) {
                        fetchNotifications();
                        markAllRead().then(() => {
                            // 標完後 0.5 秒把紅點關掉（讓使用者看到自己有按）
                            setTimeout(() => { notifBadge.style.display = 'none'; }, 500);
                        });
                    }
                });

                // 點視窗別的地方：兩個 dropdown 都關掉
                document.addEventListener('click', function () {
                    document.getElementById('accountMenu').style.display = 'none';
                    notifMenu.style.display = 'none';
                });

                // dropdown 內點擊不要關掉自己
                notifMenu.addEventListener('click', function (e) { e.stopPropagation(); });
                document.getElementById('accountMenu').addEventListener('click', function (e) { e.stopPropagation(); });

                // 首次進頁面拉一次 + 每 30 秒輪詢
                fetchNotifications();
                setInterval(fetchNotifications, 30000);
            </script>
        </div>
    </header>

    <div class="layout-container">
        <aside class="sidenav-wrapper" aria-label="主選單" style="position: relative; z-index: 20000;">
            <nav class="sidenav-box">
                <nav class="side-nav">
                    <a class="nav-icon-btn"
                           asp-controller="FrontPage"
                           asp-action="Index"
                           aria-label="首頁"
                           data-tooltip="首頁">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                            <polyline points="9 22 9 12 15 12 15 22" />
                        </svg>
                    </a>

                    <a class="nav-icon-btn" href="/Diary/DiaryList" aria-label="日記編寫" data-tooltip="日記">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                        </svg>
                    </a>

                    <a class="nav-icon-btn" href="/Review/Time" aria-label="回顧頁" data-tooltip="回顧">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <rect x="3" y="4" width="18" height="18" rx="2" />
                            <line x1="16" y1="2" x2="16" y2="6" />
                            <line x1="8" y1="2" x2="8" y2="6" />
                            <line x1="3" y1="10" x2="21" y2="10" />
                        </svg>
                    </a>

                    <a class="nav-icon-btn" href="/Task/Index" aria-label="任務頁" data-tooltip="任務中心">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M12 2L13.5 8.5L20 10L13.5 11.5L12 18L10.5 11.5L4 10L10.5 8.5Z" />
                            <path class="icon-fill" d="M5 3L5.5 5L7 5.5L5.5 6L5 8L4.5 6L3 5.5L4.5 5Z" />
                        </svg>
                    </a>

                    <a class="nav-icon-btn" href="/Home/Chart" aria-label="分析頁" data-tooltip="分析">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M3 15a9 9 0 0 1 18 0" />
                            <path d="M12 15V8" />
                            <circle class="icon-fill" cx="12" cy="15" r="2" />
                        </svg>
                    </a>

                    <a class="nav-icon-btn" href="/Home/sharewall4" aria-label="分享牆" data-tooltip="分享牆">
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
                        </svg>
                    </a>
                </nav>
            </nav>

           
        </aside>

        <main class="page-shell">
            @RenderBody()
        </main>
    </div>

    <a asp-controller="Home" asp-action="Achievement" class="giftwall-btn">★</a>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

<script>
    async function logoutAndGoWelcome() {
        try {
            const response = await fetch('/api/user/logout', {
                method: 'POST',
                credentials: 'include'
            });

            if (!response.ok) {
                alert('登出失敗');
                return;
            }

            localStorage.removeItem('userData');
            localStorage.removeItem('currentUserId');
            localStorage.removeItem('currentUserName');

            window.location.href = '/';
        } catch (error) {
            console.error('登出失敗:', error);
            alert('無法連線到伺服器');
        }
    }
</script>