<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DiaryProject</title>

    <link rel="stylesheet" href="~/css/layout.css" />
    <link rel="stylesheet" href="~/css/components.css" />
    <link rel="stylesheet" href="~/css/modal.css" />

    @RenderSection("Styles", required: false)
</head>
<body>
    <header class="topbar">
        <a asp-controller="Home" asp-action="Index" class="topbar-logo">Moody</a>

        <div class="topbar-search-wrap">
            <div class="search-box">
                <span class="search-icon">⌕</span>
                <input class="search-input" type="text" placeholder="Search my journal" />
            </div>
        </div>

        <div class="topbar-actions">
            <button class="top-icon-btn" type="button" aria-label="通知" onclick="openNotification()">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                    <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                </svg>
            </button>
            @* <button type="button" class="action-btn" aria-label="通知">🔔</button> *@
            @* <button type="button" class="action-btn" aria-label="個人資料">👤</button> *@

            <button class="top-icon-btn" type="button" aria-label="使用者">
                <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
            </button>

        </div>
    </header>

    <div class="layout-container">
        <aside class="sidenav-wrapper" aria-label="主選單">
            <nav class="sidenav-box">
                <a asp-controller="Home" asp-action="Index" class="nav-link">首頁</a>
                <a asp-controller="Review" asp-action="Time" class="nav-link">回顧</a>
                <a asp-controller="Task" asp-action="Index" class="nav-link">任務</a>
                <button type="button" class="nav-link">月</button>
                <button type="button" class="nav-link">分</button>
                <button type="button" class="nav-link">享</button>
            </nav>

            <button type="button" class="giftwall-btn">★</button>
        </aside>

        <main class="page-shell">
            @RenderBody()
        </main>
    </div>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>