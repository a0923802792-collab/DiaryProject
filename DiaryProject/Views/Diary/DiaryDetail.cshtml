@model DiaryProject.ViewModels.Diary.Diary_Detail

@{
    ViewData["Title"] = "日記詳情";

    DateTime diaryDate;
    bool isValidDate = DateTime.TryParse(Model.DiaryDate, out diaryDate);

    var dayNumber = isValidDate ? diaryDate.Day.ToString() : "";
    var weekName = isValidDate ? $"星期{("日一二三四五六"[(int)diaryDate.DayOfWeek])}" : "";
    var displayDate = isValidDate ? diaryDate.ToString("yyyy年M月d日") : Model.DiaryDate;
    var hasMedia = Model.MediaUrl != null && Model.MediaUrl.Count > 0;
    int? prevId = ViewBag.PrevId != null ? Convert.ToInt32(ViewBag.PrevId) : null;
    int? nextId = ViewBag.NextId != null ? Convert.ToInt32(ViewBag.NextId) : null;

    // 從列表頁帶進來的篩選條件。
    // 這些條件會繼續帶到「返回 / 上一篇 / 下一篇」，避免切換時離開目前篩選結果。
    var filterTemplateType = ViewBag.FilterTemplateType as string ?? "";
    var filterVisibility = ViewBag.FilterVisibility as string ?? "";
    var filterKeyword = ViewBag.FilterKeyword as string ?? "";
    var filterSortOrder = ViewBag.FilterSortOrder as string ?? "desc";
    var filterPeriod = ViewBag.FilterPeriod as string ?? "all";
    var filterStartDate = ViewBag.FilterStartDate as string ?? "";
    var filterEndDate = ViewBag.FilterEndDate as string ?? "";
    var filterTags = ViewBag.FilterTags as string ?? "";
}

@section Styles {
    <link rel="stylesheet" href="~/css/diary/diary-common.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/diary/diary_detail.css" asp-append-version="true" />
}

<main class="main-content diary-detail-page">
    <input type="hidden" id="diaryId" value="@Model.DiaryId" />

    <div class="top-nav-row">
        @* 返回列表時保留原本篩選條件 *@
        <a class="back-btn"
           id="backBtn"
           href="@Url.Action("DiaryList", "Diary", new {
               templateType = filterTemplateType,
               visibility = filterVisibility,
               keyword = filterKeyword,
               sortOrder = filterSortOrder,
               period = filterPeriod,
               startDate = filterStartDate,
               endDate = filterEndDate,
               tags = filterTags
           })">返回</a>

        @* 上一篇：排序清單中的前一筆。若前端有儲存篩選後清單，diary_detail.js 會再用更精準的順序覆蓋。 *@
        @if (prevId.HasValue)
        {
            <a class="nav-btn"
               id="prevBtn"
               href="@Url.Action("DiaryDetail", "Diary", new {
                   id = prevId.Value,
                   templateType = filterTemplateType,
                   visibility = filterVisibility,
                   keyword = filterKeyword,
                   sortOrder = filterSortOrder,
                   period = filterPeriod,
                   startDate = filterStartDate,
                   endDate = filterEndDate,
                   tags = filterTags
               })">
                上一篇
            </a>
        }
        else
        {
            <button class="nav-btn" id="prevBtn" type="button" disabled>上一篇</button>
        }

        @* 下一篇：排序清單中的下一筆。 *@
        @if (nextId.HasValue)
        {
            <a class="nav-btn"
               id="nextBtn"
               href="@Url.Action("DiaryDetail", "Diary", new {
                   id = nextId.Value,
                   templateType = filterTemplateType,
                   visibility = filterVisibility,
                   keyword = filterKeyword,
                   sortOrder = filterSortOrder,
                   period = filterPeriod,
                   startDate = filterStartDate,
                   endDate = filterEndDate,
                   tags = filterTags
               })">
                下一篇
            </a>
        }
        else
        {
            <button class="nav-btn" id="nextBtn" type="button" disabled>下一篇</button>
        }
    </div>

    <div class="meta-row-card">
        <div class="date-block">
            <div class="num" id="metaDayNum">@dayNumber</div>
            <div class="dname" id="metaDayName">@weekName</div>
        </div>

        <div class="flex-main-min">
            <div id="metaPrimary" class="meta-primary">
                @displayDate
                @foreach (var tag in Model.TagName)
                {
                    <span class="tag-pill">@tag</span>
                }
            </div>

            <div id="metaSecondary" class="meta-secondary">
                <span>@Model.DiaryTime</span>
                @if (!string.IsNullOrWhiteSpace(Model.WeatherType))
                {
                    <span>｜</span>
                    <span>@Model.WeatherType</span>
                }
            </div>
        </div>

        <div class="meta-actions">
            <form id="shareDiaryForm" method="post" asp-controller="Diary" asp-action="ToggleShare" style="display:inline;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.DiaryId" />
                <button class="action-btn share-state @(Model.Visibility == "已分享" ? "is-shared" : "is-private")"
                        id="shareBtn"
                        type="button"
                        data-visibility="@Model.Visibility"
                        onclick="showShareConfirmModal()">
                    @(Model.Visibility == "已分享" ? "🔓" : "🔒") @Model.Visibility
                </button>
            </form>
            <a class="action-btn" id="editDiaryBtn" href="@Url.Action("DiaryEdit", "Diary", new { id = Model.DiaryId })">✏️ 編輯日記</a>
            <form id="deleteDiaryForm" method="post" asp-controller="Diary" asp-action="DeleteDiary" style="display:inline;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@Model.DiaryId" />
                <button class="action-btn danger" type="button" onclick="showDiaryDeleteModal()">✕ 刪除日記</button>
            </form>
        </div>
    </div>

    <div class="content-grid">
        @if (Model.TemplateType == "mood")
        {
            @await Html.PartialAsync("_DetailMood", Model)
        }
        else
        {
            @await Html.PartialAsync("_DetailNormal", Model)
        }

        <div class="images-panel @(hasMedia ? "" : "is-empty")">
            <div class="empty-state" id="emptyState">
                <div class="empty-state-icon">🖼️</div>
                <div class="empty-state-title">尚無圖片或繪圖</div>
                <div class="empty-state-desc">編輯日記時可以上傳照片<br>或加入手繪塗鴉</div>
            </div>

            <div class="inline-preview" id="inlinePreview">
                <div class="preview-display" id="previewDisplay"></div>
                <div class="preview-toolbar">
                    <button class="preview-nav" id="previewPrevBtn" type="button" aria-label="上一張" onclick="shiftPreview(-1)" disabled>‹</button>
                    <span class="preview-counter" id="previewCounter">1 / 10</span>
                    <button class="preview-nav" id="previewNextBtn" type="button" aria-label="下一張" onclick="shiftPreview(1)" disabled>›</button>
                </div>
            </div>

            <div class="thumb-col">
                <div class="images-header" data-field="DiaryMedia.Count">@Model.MediaUrl.Count 張圖片</div>
                <div class="images-grid" id="imagesGrid" data-field="DiaryMedia.FileUrl[]">
                    @if (hasMedia)
                    {
                        for (var i = 0; i < Model.MediaUrl.Count; i++)
                        {
                            var rawUrl = Model.MediaUrl[i] ?? string.Empty;
                            var resolvedUrl = rawUrl.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
                                              rawUrl.StartsWith("https://", StringComparison.OrdinalIgnoreCase)
                                ? rawUrl
                                : Url.Content(rawUrl.StartsWith("~", StringComparison.Ordinal)
                                    ? rawUrl
                                    : $"~{(rawUrl.StartsWith("/", StringComparison.Ordinal) ? rawUrl : "/" + rawUrl)}");
                            <div class="img-thumb" data-kind="image" data-preview-value="@resolvedUrl" onclick="openPreview(@i)">
                                <img src="@resolvedUrl" alt="日記圖片 @(i + 1)" loading="lazy" />
                            </div>
                        }
                    }
                </div>
            </div>
        </div>
    </div>
</main>

<div class="modal-overlay" id="shareConfirmModal">
    <div class="modal">
        <h3>確認分享</h3>
        <p id="shareConfirmText">確定要切換分享狀態嗎？</p>
        <div class="modal-buttons">
            <button type="button" class="modal-btn" onclick="hideModal('shareConfirmModal')">取消</button>
            <button type="button" class="modal-btn danger" onclick="confirmDiaryShare()">確定</button>
        </div>
    </div>
</div>

<div class="modal-overlay" id="deleteModal">
    <div class="modal">
        <h3>確認刪除</h3>
        <p>確定要刪除這篇日記嗎？<br>移除後無法復原。</p>
        <div class="modal-buttons">
            <button type="button" class="modal-btn" onclick="hideModal('deleteModal')">取消</button>
            <button type="button" class="modal-btn danger" onclick="confirmDiaryDelete()">確定刪除</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/diary/diary_detail.js" asp-append-version="true"></script>
}
