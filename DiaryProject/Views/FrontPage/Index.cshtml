@{
    ViewData["Title"] = "Front";
}

<section class="front-home">
    <div class="front-home-card">
        <h1>Moody Front</h1>
        <p>這裡是登入後的 MVC 首頁。</p>
    </div>
</section>

@section Styles {
    <style>
        .front-home {
            padding: 32px;
        }

        .front-home-card {
            background: #FDFBF7;
            border: 1.5px solid #1f1f1f;
            border-radius: 28px;
            padding: 32px;
            min-height: 220px;
        }

        .front-home-card h1 {
            margin: 0 0 12px 0;
            font-size: 40px;
        }

        .front-home-card p {
            margin: 0;
            font-size: 18px;
            color: #5f5a52;
        }
    </style>
}