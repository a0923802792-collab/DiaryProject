@{
    ViewData["Title"] = "Profile";
}

<div class="frontpage-react-host">
    <div id="profile-root"></div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/entry/assets/src.css" />
    <style>
        /* 強制讓首頁背景有格紋 */
        body {
            background-color: #FDFBF7 !important;
            background-image: linear-gradient(to right, #e5e7eb 1px, transparent 1px), linear-gradient(to bottom, #e5e7eb 1px, transparent 1px) !important;
            background-size: 24px 24px !important;
        }
        /* React 容器透明，讓 body 的格紋透出來 */
        .frontpage-react-host,
        #front-home-root,
        #front-home-root > div {
            background: transparent !important;
        }
    </style>
}

@section Scripts {
    <script type="module" src="~/entry/assets/profile.js" asp-append-version="true"></script>
}